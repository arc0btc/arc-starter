#!/usr/bin/env bun

// skills/whop-sales/cli.ts
//
// CLI for the `whop-sales` skill: the EXECUTABLE consolidation of the sales
// doctrine (SKILL.md). `pitch` turns a sales signal into a composed,
// doctrine-shaped pitch — deterministic glue only: NO LLM call, NO credentials,
// NO network, NO write side-effects (it composes pitch TEXT; it does not post).
// The pure composer lives in lib/compose.ts (shared with the P9 sensor).
//
// `tick-acquisition` runs the P9 autonomous acquisition lane once (bypassing the
// sensor's interval gate) — for on-demand verification, mirroring the `whop`
// skill's `tick-replies` / `tick-synthesis`.
//
// Scope boundary (quest hash-it-out-go-to-market): P5 made the motion runnable
// (compose a pitch for a signal). P9 wires the posting side-effect + the BLOCKING
// spend caps / rate limits / dedup / proof-block (lib/enforcement.ts) + the
// recurring lane (sensor.ts) into the autonomous dispatch loop.
//
// Usage:
//   arc skills run --name whop-sales -- pitch --class A --signal "asked in the forum about agent nonces" [--name alice] [--channel x|forum] [--proof <txid|url>]
//   arc skills run --name whop-sales -- doctrine
//   arc skills run --name whop-sales -- tick-acquisition       # run the acquisition lane once
//   arc skills run --name whop-sales -- help

import { parseFlags } from "../../src/utils.ts";
import { PAID_ROOM_PRODUCT_URL, PAID_ROOM_CHECKOUT_URL, PROMO_CODE } from "../../src/constants.ts";
import { composePitch, NEVER_SAY } from "./lib/compose.ts";
import { getCredential } from "../../src/credentials.ts";
import { refreshLeads, loadLeadStore } from "./lib/lead-source.ts";
import { loadXCreds } from "../social-x-posting/lib/x-api.ts";
import { surfaceLeads } from "./sensor.ts";

function fail(message: string): never {
  process.stderr.write(`whop-sales: ${message}\n`);
  process.exit(1);
}

function cmdPitch(flags: Record<string, string>): void {
  const result = composePitch({
    cls: flags.class ?? "A",
    signal: flags.signal ?? "",
    name: flags.name,
    channel: flags.channel,
    proof: flags.proof,
    forcedElement: flags.element,
  });

  if (!result.ok) fail(result.error ?? "compose failed");

  // Preserve the P5 output shape (re-grouped guardrails + mode/on_convert framing)
  // so the doctrine output stays stable; the composer is the single source of truth.
  const who = flags.name ? `@${flags.name}` : "you";
  const out = {
    mode: "DRY — composition only; the posting side-effect + BLOCKING caps are the P9 sensor's lane",
    lead_class: result.lead_class,
    intent: result.intent,
    lead_note: result.lead_note,
    ladder_rung: result.ladder_rung,
    pitch_element_used: result.pitch_element_used,
    element_matched: result.element_matched,
    channel: result.channel,
    composed_pitch: result.composed_pitch,
    proof_required: result.proof_required,
    receipt_standard: result.receipt_standard,
    guardrails: {
      one_ask: true,
      give_3x_before_ask: "verify ≥3 value touches precede this ask for " + who + " (the P9 lane BLOCKS otherwise)",
      one_pitch_per_7d: "check db/whop-sales-outreach.json before sending (the P9 lane BLOCKS a re-pitch inside 7d)",
      never_say_clean: result.never_say_clean,
      never_say_hits: result.never_say_hits,
    },
    on_convert: "trigger ship-board onboarding (P4 rev B): the P9 lane queues a day-1 + day-5 ship-log nudge — spectator → co-author (the retention engine).",
  };

  for (const w of result.warnings) process.stderr.write(`whop-sales: WARNING — ${w}\n`);
  console.log(JSON.stringify(out, null, 2));
}

function cmdDoctrine(): void {
  console.log(
    [
      "whop-sales — consolidated motion (see SKILL.md for the full doctrine)",
      "",
      "PIPELINE (signal → retain):",
      "  1. SIGNAL   — surface Class A/B/C leads from reactive/synthesis lanes + X/forum engagement.",
      "  2. QUALIFY  — BANT+ lite: is this a right-audience builder/operator? what did they actually engage?",
      "  3. PITCH    — ONE message, value-first, sell L1 ($49); cite the specific signal; one element only.",
      "  4. FOLLOW   — at most ONE callback to the same thread; then stop (no spirals).",
      "  5. CONVERT  — attributed checkout link (?a=arc0btc) + FREEMONTH promo in the FIRST REPLY (never post body).",
      "  6. ONBOARD  — ship-board: new member posts one attributable ship-log within 7 days (P4 rev B).",
      "  7. RETAIN   — the two-way member ship-board is the retention engine, not Arc's content treadmill.",
      "",
      "ENFORCEMENT (P9 lane, BLOCKING — not warnings): 1–2/day cap · give-3x-before-ask · 7-day dedup · claim→proof.",
      "CADENCE: lean + capped — 1–2 substantive outreaches/day max; give value 3x before each ask.",
      "RECEIPT STANDARD: every cited claim/number ships its verifiable link (txid/explorer/ledger) in the first reply.",
      "PROMO: " + PROMO_CODE + " (first month free, new members) — surfaced in the CTA copy.",
      "NEVER SAY: " + NEVER_SAY.join(", "),
      "ATTRIBUTION: product=" + PAID_ROOM_PRODUCT_URL + " | checkout=" + PAID_ROOM_CHECKOUT_URL,
    ].join("\n"),
  );
}

async function cmdTickAcquisition(): Promise<void> {
  // Run the P9 recurring acquisition lane ONCE, bypassing the interval self-gate.
  // Initialize the DB singleton first (the in-loop sensor runner does this — see
  // src/sensors.ts) so member-exclusion + the onboarding-nudge read work the same
  // standalone as they do inside the dispatch loop.
  const { initDatabase } = await import("../../src/db.ts");
  initDatabase();
  const { runAcquisitionLane } = await import("./sensor.ts");
  await runAcquisitionLane();
}

async function cmdRefreshLeads(): Promise<void> {
  // Refresh the non-member lead store (db/whop-leads.json) from BOTH live channels
  // — the free forum (Whop company key, forum:read) and X (@arc0btc mentions, X
  // OAuth creds) — then preview the classified candidates. This is the standalone
  // entry to the same refresh the acquisition lane runs at the top of each tick.
  const apiKey = (await getCredential("whop", "company_api_key")) || null;
  const xCreds = await loadXCreds();
  const r = await refreshLeads({ apiKey, xCreds, log: (m) => process.stderr.write(m + "\n") });
  const store = loadLeadStore();
  // Preview only: member-exclusion is applied in the LIVE lane (it reads active
  // members from whop_event_log); here we pass an empty set so the preview shows
  // the full lead store.
  const candidates = surfaceLeads(store, new Set<string>());
  process.stdout.write(
    JSON.stringify(
      {
        refreshed: r,
        note: "candidates = STORE preview; member-exclusion is applied in the live lane, not here",
        candidates: candidates.map((c) => ({
          lead_id: c.lead_id,
          username: c.username,
          cls: c.cls,
          value_touches: c.value_touches,
          channel: c.channel,
          route: c.route,
          signal: c.signal,
        })),
      },
      null,
      2,
    ) + "\n",
  );
}

function printHelp(): void {
  console.log(
    [
      "whop-sales — executable sales doctrine (composes pitches; does NOT post)",
      "",
      "Commands:",
      "  pitch --class A|B|C --signal \"<what they did>\" [--name <h>] [--channel x|forum] [--element blog|forum|x|infra] [--proof <txid|url>]",
      "  doctrine            print the consolidated pipeline + cadence + guardrails",
      "  tick-acquisition    run the autonomous acquisition lane once (bypass the interval gate)",
      "  refresh-leads       refresh the non-member lead store (forum + X) + preview candidates",
      "  help                this message",
    ].join("\n"),
  );
}

async function main(): Promise<void> {
  const args = process.argv.slice(2);
  const command = args[0];
  const flags = parseFlags(args.slice(1)).flags;

  if (!command || command === "help" || command === "--help") {
    printHelp();
    return;
  }

  switch (command) {
    case "pitch":
      cmdPitch(flags);
      break;
    case "doctrine":
      cmdDoctrine();
      break;
    case "tick-acquisition":
      await cmdTickAcquisition();
      break;
    case "refresh-leads":
      await cmdRefreshLeads();
      break;
    default:
      fail(`unknown command: ${command}. Run with no args for help.`);
  }
}

main().catch((error) => {
  fail(error instanceof Error ? error.message : String(error));
});
